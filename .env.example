# Copy to .env and fill in values (never commit .env).

# Supabase — Project Settings → API (required for app, tests, sitemap API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical site URL for metadata, sitemap, and JSON-LD (recommended in production)
# On Vercel, VERCEL_URL is used as fallback if unset.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional — Playwright when not using default http://127.0.0.1:3000
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
